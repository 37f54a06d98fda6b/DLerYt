name: Manual Workflow
on:
  workflow_dispatch:
    inputs:
      video_url:
        description: 'YouTube video URL'
        required: true
        type: string
      quality:
        description: 'Video quality'
        required: false
        default: '1080p'
        type: choice
        options:
          - '1080p'
          - '720p'
          - '480p'

jobs:
  download:
    runs-on: ubuntu-latest
    steps:
      - name: Use inputs
        run: |
          echo "URL: ${{ inputs.video_url }}"
          echo "Quality: ${{ inputs.quality }}"
